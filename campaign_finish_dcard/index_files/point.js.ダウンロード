$(function(){
  var script= document.createElement('script');
  script.src = 'https://service.smt.docomo.ne.jp/cgi7m/v2_0/getdpointinf?callback=mycallback&ptn_code=0022';
  document.getElementsByTagName('head')[0].appendChild(script);
});
function mycallback(data){
  if(data.common.result_code == "1000" &&
  navigator.userAgent.search(/iPhone|Android/) != -1 &&
  $.cookie('dcmx_last_login') != '0'){
    if (data.data.user_info_disp_flg == 0){
      $('.point__number').text('****');
    }else if(data.data.user_info_disp_flg == 1){
      if(data.data.d_pt_info.total_d_pt){
    	var sum_points = data.data.d_pt_info.total_d_pt;
        if(String(Math.abs(sum_points)).length >= 7){
          if(sum_points >= 0){
            $('.point__number').text('999,999');
          }else{
            $('.point__number').text('-999,999');
          }
        }else{
          $('.point__number').text(String(sum_points).replace( /(\d)(?=(\d\d\d)+(?!\d))/g, '$1,' ));
        }
        if (sum_points - 0 < 0){
          $('.point__number').css("color","#c00000");
          $('.point__p-icon').css("color","#9c6666");
          if(String(Math.abs(sum_points)).length >= 6){
            $('.point__number').css("font-size","13px");
          }
        }
      }
    }
  }
}
