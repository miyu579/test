var resize_flag = false;
// 画面読み込み時の動作
$(document).ready(function(){
  var win_width = $(window).width();
  // accordionの開閉
  accordion();
  listAccordion();

  // fittext(テキストサイズ自動調整)
  $('.fittext70').fitText(0.7);
  $('.fittext100').fitText(1.0);
  $('.fittext110').fitText(1.1);

  // PCで電話番号リンク無効
  tel_link();

  // 要素の動的挿入
  afterloadElements();

  // タブ切り替え
  if($('.card-navi').length) tabHash();

  // スマフォ時に'display_sp-only'表示する
  displayUaOnMobile('.display_sp-only');

  // 前回開いたサブナビゲーションのタブの切り替え
  tabReminder();

  //iOSのみ表示のものをiOS以外で削除
  displayios();

  // PC、SP画像切替
  image_switch(win_width);

  // 要素の高さを合わせる
  uniform_height(win_width);

  setTimeout(function() {
    //ポップアップウィンドウ呼び出し
    //popupWindow();
    //ログインモーダル呼出
    //loginPopup();
    // copyright年号修正
    copyright();
    // accordionの設定
    checkListAccordion(win_width);
  }, 500);
});

// 画面読み込み時とリサイズ時の動作
$(window).on('resize', function(){
  // 画面幅習得
  var win_width = $(window).width();

  if (resize_flag !== false) {
    clearTimeout(resize_flag);
  }

  // 要素の高さを合わせる
  uniform_height(win_width);

  // PC、SP画像切替
  image_switch(win_width);

  timer = setTimeout(function() {
    // accordionの設定
    checkListAccordion(win_width);
  }, 1000);
});

